# Copy to .env.local for local development:  cp .env.local.example .env.local
# .env.local is gitignored (see .gitignore) and never reaches origin.
#
# Leave this file empty / unfilled to run in NO-DATABASE mode:
#   npm run dev  ->  http://localhost:3000/demo  (static demo, no auth, no Firestore)
#
# Fill these to run the FULL flow locally. Point them at a SEPARATE "dev"
# Firebase project, NOT production, so local testing never touches live data.

# --- Firebase web config (client) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server, used by API routes for Firestore writes) ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the full key in double quotes; \n escapes are normalized automatically.
FIREBASE_ADMIN_PRIVATE_KEY=""

# --- OpenAI (server, generation/critique/master-prompt) ---
OPENAI_API_KEY=

# --- Optional ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000
