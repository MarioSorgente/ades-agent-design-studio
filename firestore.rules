rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function immutableUnchanged(field) {
      return !(field in request.resource.data) || request.resource.data[field] == resource.data[field];
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        // Never allow the client to self-escalate plan/admin flags.
        && immutableUnchanged("plan")
        // Server-controlled generation usage flags must remain immutable from client writes.
        && immutableUnchanged("hasGeneratedProjectEver")
        && immutableUnchanged("generationCount")
        && immutableUnchanged("isAdmin");
      allow delete: if false;
    }

    match /usage/{uid} {
      // Usage records are authoritative cost-control state. Only trusted server/admin SDK writes are allowed.
      allow read: if isOwner(uid);
      allow write, delete, create, update: if false;
    }

    match /projects/{projectId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if false;
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && immutableUnchanged("ownerUid")
        && immutableUnchanged("createdAt")
        && immutableUnchanged("id")
        && immutableUnchanged("status");
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /paymentInterest/{docId} {
      allow read: if false;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    match /feedback/{docId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
